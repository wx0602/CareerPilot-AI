APP_ENV=production
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DATABASE?sslmode=require
UPLOAD_DIR=/tmp/careerpilot/uploads
CORS_ORIGINS=https://your-careerpilot.vercel.app
CORS_ORIGIN_REGEX=
MAX_UPLOAD_BYTES=4000000
PROVIDER_MODE=real
KNOWLEDGE_DATABASE_PATH=../knowledge/question_bank/questions.sqlite3
KNOWLEDGE_CHROMA_DIR=/tmp/careerpilot/chroma_store
DEMO_ACCOUNT=demo@careerpilot.local
DEMO_PASSWORD=CHANGE_THIS_PASSWORD
AUTH_TOKEN_TTL_HOURS=24
REMEMBER_TOKEN_TTL_DAYS=30
GUEST_TOKEN_TTL_HOURS=2
LLM_API_KEY=YOUR_LLM_API_KEY
LLM_BASE_URL=https://your-llm-provider.example/v1
LLM_MODEL=YOUR_MODEL_NAME
JSEARCH_API_KEY=YOUR_OPENWEB_NINJA_JSEARCH_KEY
JSEARCH_TIMEOUT_SECONDS=10
